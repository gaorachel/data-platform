# Copy to .env (gitignored) and fill in.
#
# Source values from terraform output:
#   cd ../../terraform/iceberg && terraform init && terraform output
#
# AWS_REGION and S3_BUCKET come from terraform/shared.
# EMR_APPLICATION_ID and EMR_EXECUTION_ROLE_ARN come from terraform/iceberg.

AWS_REGION=eu-west-1
S3_BUCKET=data-platform-main-<account_id>
EMR_APPLICATION_ID=<terraform output emr_serverless_application_id>
EMR_EXECUTION_ROLE_ARN=<terraform output emr_serverless_execution_role_arn>
